# Chat Research Interface — environment variables
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ── OpenAI (REQUIRED) ─────────────────────────────────────────────
# Server-side only. The browser bundle MUST NOT see this key.
# The `api/chat.js` Vercel serverless function reads it and proxies
# requests to the Responses API.
OPENAI_API_KEY="sk-proj-..."

# ── Supabase (REQUIRED, client-side) ──────────────────────────────
# REACT_APP_ prefix means CRA exposes these to the browser bundle.
# Get from Supabase dashboard → Settings → API.
REACT_APP_SUPABASE_URL="https://your-project-ref.supabase.co"
REACT_APP_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ── Application config ────────────────────────────────────────────
# Session timeout in minutes (the deployed study uses 3).
REACT_APP_DEFAULT_TIMEOUT=3

# ── Optional ──────────────────────────────────────────────────────
# REACT_APP_COMPLETION_URL="https://your-redirect.example.com/complete"
# REACT_APP_DEBUG_MODE=false

# Deployment checklist
# [ ] Replace placeholders with real credentials
# [ ] In Vercel dashboard: add the same vars under Settings → Environment Variables
# [ ] OPENAI_API_KEY must NOT have a REACT_APP_ prefix (server-side only)
# [ ] Verify Supabase schema is deployed (see supabase-setup.sql)
# [ ] Smoke-test a scenario URL: /scenario/aita-1?PROLIFIC_PID=test123
