# Chat Research Interface — environment variables
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ── OpenAI (REQUIRED) ─────────────────────────────────────────────
# Server-side only. The browser bundle MUST NOT see this key.
# The `api/chat.js` Vercel serverless function reads it and proxies
# requests to the Responses API.
OPENAI_API_KEY="sk-proj-..."

# ── Supabase — server-side only (REQUIRED) ────────────────────────
# Used by Vercel serverless functions in api/. Never exposed to the browser.
# Get from Supabase dashboard → Settings → API.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # service_role key — keep secret

# ── Application config ────────────────────────────────────────────
# Session timeout in minutes (the deployed study uses 3).
REACT_APP_DEFAULT_TIMEOUT=3

# ── Security ──────────────────────────────────────────────────────
# Set to your production domain to block cross-origin API abuse.
# Leave unset (or set to http://localhost:3000) during local dev.
ALLOWED_ORIGIN="https://your-project.vercel.app"

# ── Optional ──────────────────────────────────────────────────────
# REACT_APP_COMPLETION_URL="https://your-redirect.example.com/complete"
# REACT_APP_DEBUG_MODE=false

# Deployment checklist
# [ ] Replace placeholders with real credentials
# [ ] In Vercel dashboard: add SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
#     OPENAI_API_KEY, and ALLOWED_ORIGIN under Settings → Environment Variables
# [ ] None of the above should have a REACT_APP_ prefix (all server-side only)
# [ ] Run rls-cleanup.sql in Supabase SQL editor to remove anon write access
# [ ] Verify Supabase schema is deployed (see supabase-setup.sql)
# [ ] Smoke-test a scenario URL: /scenario/aita-1?PROLIFIC_PID=test123
